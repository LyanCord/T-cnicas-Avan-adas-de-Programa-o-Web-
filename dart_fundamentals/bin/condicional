import 'dart:io';

void main(){
  stdout.write('Qual a distancia ');
  String? valor = stdin.readLineSync();

  if (valor==null){
    stdout.write('O campo distancia é obrigatorio!\n');
    return;
  }

  double? distancia = double.tryParse(valor) ?? 0;
  double? premio;

  if (distancia < 800){
    premio = 5000;
  }else if (distancia>= 800 && distancia <1500){
    premio = 10000
  }

}